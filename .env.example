# Vercel KV (Redis) Configuration
# Get these values from Vercel Dashboard > Project > Storage > Connect Database

KV_URL=redis://default:password@host:port
KV_REST_API_URL=https://host:port
KV_REST_API_TOKEN=your_token_here
KV_REST_API_READ_ONLY_TOKEN=your_read_only_token_here

# PostgreSQL Configuration (for Railway/self-hosted)
DATABASE_URL=postgresql://user:password@host:port/database

# Security
ADMIN_PASSWORD=your_secure_password_here
JWT_SECRET=your_jwt_secret_here

# Server
PORT=3000
NODE_ENV=development

# CORS (allowed origins, comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate Limiting
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_MS=900000
