{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/admin.html",
      "dest": "/admin.html"
    },
    {
      "src": "/admin-styles.css",
      "dest": "/admin-styles.css"
    },
    {
      "src": "/admin-script.js",
      "dest": "/admin-script.js"
    },
    {
      "src": "/styles.css",
      "dest": "/styles.css"
    },
    {
      "src": "/script.js",
      "dest": "/script.js"
    },
    {
      "src": "/(.+\\.css)",
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.js)",
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.ico)",
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.png)",
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.jpg)",
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.mp3)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
